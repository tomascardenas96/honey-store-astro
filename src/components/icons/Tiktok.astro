---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"svg"> {
  size?: number | string;
}

// Logo de TikTok (marca registrada, uso nominativo), inline para no depender
// del runtime de astro-icon, que rompe en `astro dev` con Cloudflare (workerd).
// Es un glyph sólido, por eso usa `fill` en vez de `stroke`.
const { size = 24, ...rest } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="currentColor"
  aria-hidden="true"
  focusable="false"
  {...rest}
>
  <path
    d="M16.6 5.82a4.28 4.28 0 0 1-1.05-2.82h-3.2v12.9a2.58 2.58 0 1 1-2.58-2.58c.27 0 .53.04.78.12V10.2a5.8 5.8 0 0 0-.78-.05 5.72 5.72 0 1 0 5.72 5.72V9.01a7.5 7.5 0 0 0 4.36 1.4V7.2a4.28 4.28 0 0 1-3.25-1.38z"
  ></path>
</svg>
