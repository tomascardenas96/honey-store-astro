---
import { Image } from "astro:assets";
import AdBanner from "@/assets/images/ad.png";
import Container from "../Container.astro";
---

<section class="hidden lg:flex my-16">
  <Container>
    <div class="p-1 rounded-4xl border border-dashed border-honey-500">
      <Image
        src={AdBanner}
        alt="Banner publicitario de miel 100% pura"
        class="rounded-3xl object-cover h-105"
      />
    </div>
  </Container>
</section>
