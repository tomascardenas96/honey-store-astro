---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import Bee from "@/assets/images/bee-decorative.png";

interface Props {
  products: CollectionEntry<"productos">[];
}

const { products } = Astro.props;

const arrowClass =
  "absolute top-1/2 z-10 grid size-11 -translate-y-1/2 place-items-center rounded-full border border-honey-200/70 bg-honey-25/90 text-honey-700 shadow-card backdrop-blur-sm transition duration-200 ease-out-soft cursor-pointer hover:scale-105 hover:bg-white hover:text-honey-900 hover:shadow-raised focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-honey-500 disabled:pointer-events-none";
---

<section class="flex flex-col mt-24 lg:mt-20 gap-2">
  <div class="flex flex-col items-center gap-5 relative">
    <h1 class="font-display text-lg lg:text-xl">Nuestros Productos</h1>
    <div class="w-14 h-0.5 absolute top-9 lg:top-11 bg-amber-400"></div>
    <Image src={Bee} alt="Abeja decorativa" class="w-14 lg:w-16" />
  </div>

  <div class="mt-10" data-carousel>
    <div class="relative sm:px-[9%] md:px-[10%]">
      <ul
        data-carousel-track
        class="flex gap-6 sm:gap-2 md:gap-0 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-4 scrollbar-none [&::-webkit-scrollbar]:hidden"
      >
        {
          products.map((product) => (
            <li class="snap-center shrink-0 basis-full sm:basis-1/2 lg:basis-1/3">
              <article class="flex flex-col gap-6 lg:gap-6 rounded-card p-0 h-140 sm:h-137 w-72 sm:w-60 md:w-68 lg:w-56 mx-auto lg:items-center">
                <Image
                  src={product.data.image}
                  alt={product.data.name}
                  class="w-full h-full object-cover"
                />
                <div class="h-full flex flex-col gap-6 lg:gap-6">
                  <h3 class="font-body text-md 2xl:text-sm font-semibold lg:max-w-[22ch] tracking-wide">
                    {product.data.name.toUpperCase()}
                  </h3>
                  <p class="text-smq lg:text-sm text-[#000000cb] leading-6">
                    {product.data.description}
                  </p>
                  <div class="flex h-24 border-t border-[#828282] items-center justify-between">
                    <span class="font-semibold text-xl lg:text-lg">
                      ${product.data.price}
                    </span>
                    <button class="text-md lg:text-xs lg:font-light border-2 px-8 lg:px-7 py-3 lg:py-3 tracking-wide">
                      AÑADIR
                    </button>
                  </div>
                </div>
              </article>
            </li>
          ))
        }
      </ul>

      <button
        type="button"
        data-carousel-prev
        aria-label="Producto anterior"
        class={`${arrowClass} left-3 disabled:opacity-40`}
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-5"
          aria-hidden="true"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
      </button>
      <button
        type="button"
        data-carousel-next
        aria-label="Producto siguiente"
        class={`${arrowClass} right-3 disabled:opacity-0`}
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-5"
          aria-hidden="true"
        >
          <path d="m9 18 6-6-6-6"></path>
        </svg>
      </button>
    </div>

    <div
      class="mt-1 lg:mt-5 flex items-center justify-center gap-0"
      data-carousel-dots
    >
      {
        products.map((product, i) => (
          <button
            type="button"
            data-carousel-dot
            aria-current={i === 0 ? "true" : "false"}
            aria-label={`Ir a ${product.data.name}`}
            class="group grid cursor-pointer place-items-center rounded-full p-1.5 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-honey-500"
          >
            <span class="block h-2 w-2 rounded-full bg-honey-200 transition-all duration-300 ease-out-soft group-hover:bg-honey-400 group-aria-current:w-6 group-aria-current:bg-honey-500" />
          </button>
        ))
      }
    </div>
  </div>
</section>

<script>
  import "./carousel";
</script>
