---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import Bee from "@/assets/images/bee-decorative.png";

interface Props {
  products: CollectionEntry<"productos">[];
}

const { products } = Astro.props;
---

<section class="flex flex-col mt-24">
  <div class="flex flex-col items-center gap-5 relative">
    <h1 class="font-display text-lg">Nuestros Productos</h1>
    <div class="w-14 h-0.5 absolute top-9 bg-amber-400"></div>
    <Image src={Bee} alt="Abeja decorativa" class="w-14" />
  </div>

  <div class="relative mt-10" data-carousel>
    <ul
      data-carousel-track
      class="flex gap-6 overflow-x-auto snap-x snap-mandatory scroll-smooth px-6 pb-4 scrollbar-none [&::-webkit-scrollbar]:hidden"
    >
      {
        products.map((product) => (
          <li class="snap-center shrink-0 basis-full sm:basis-1/2 lg:basis-1/3">
            <article class="flex flex-col gap-3 rounded-card p-0 h-full">
              <Image
                src={product.data.image}
                alt={product.data.name}
                class="w-full h-50 object-contain"
              />
              <h3 class="font-display text-lg">{product.data.name}</h3>
              <p class="text-sm">{product.data.description}</p>
              <span class="font-semibold">${product.data.price}</span>
            </article>
          </li>
        ))
      }
    </ul>

    <button
      type="button"
      data-carousel-prev
      aria-label="Producto anterior"
      class="absolute left-2 top-1/2 -translate-y-1/2 size-10 grid place-items-center rounded-full bg-white/90 shadow-raised"
    >
      ‹
    </button>
    <button
      type="button"
      data-carousel-next
      aria-label="Producto siguiente"
      class="absolute right-2 top-1/2 -translate-y-1/2 size-10 grid place-items-center rounded-full bg-white/90 shadow-raised"
    >
      ›
    </button>
  </div>
</section>

<script>
  import "./carousel";
</script>
