---
// Sección reutilizable del footer: círculo con icono + título con subrayado,
// y un slot para el contenido (que queda alineado bajo el título).
// El icono se pasa por el slot nombrado `icon`.
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<section class="flex gap-4">
  <span
    class="grid size-11 shrink-0 place-items-center rounded-full border border-honey-400 text-honey-500"
  >
    <slot name="icon" />
  </span>

  <div class="flex flex-1 flex-col gap-4 pt-1">
    <div class="flex flex-col gap-1.5 mb-1">
      <h3 class="text-md font-semibold tracking-wide text-honey-900 uppercase">
        {title}
      </h3>
      <span class="h-0.5 w-10 rounded-full bg-honey-500"></span>
    </div>
    <slot />
  </div>
</section>
